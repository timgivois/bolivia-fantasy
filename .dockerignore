# Keep the Docker build context lean. NOTE: every workspace project listed in
# pnpm-workspace.yaml (apps/*, packages/*, tools/*) must stay in the context —
# `pnpm install --frozen-lockfile` fails if a workspace project is missing.

# VCS / CI
.git
.github

# Dependencies — reinstalled inside the image
node_modules
**/node_modules

# Build outputs — rebuilt inside the image
**/dist
**/.next
**/.turbo
**/*.tsbuildinfo
**/coverage

# Environment files (never bake secrets into images)
.env
.env.*
**/.env
**/.env.*
!.env.example

# Docker / deploy plumbing (not needed inside the images)
**/Dockerfile
.dockerignore
docker-compose.yml
**/railway.json
docs

# Misc
**/*.log
.DS_Store
