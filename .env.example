# --- Database ---
# Postgres connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgres://bolivia_fantasy:bolivia_fantasy@localhost:5432/bolivia_fantasy

# --- External data provider ---
# API-Football key used by the worker to poll fixtures/stats
API_FOOTBALL_KEY=
# How often (in minutes) the worker polls for live data
POLL_INTERVAL_MIN=12

# --- API server (apps/api) ---
PORT=4000

# --- Web app (apps/web) ---
# Base URL the browser uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Auth (Auth.js) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
